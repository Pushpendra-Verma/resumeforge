# Google Sign-In (client-side, Google Identity Services)
# ------------------------------------------------------
# GoodResume is fully client-side, so it only needs a PUBLIC OAuth Client ID
# (no client secret, no server). Create one at:
#   https://console.cloud.google.com/apis/credentials
#   → Create credentials → OAuth client ID → Web application
#   → Authorized JavaScript origins: http://localhost:3000 (and your prod URL)
#
# Copy this file to `.env.local` and paste your Client ID below.
# When unset, the app runs in a clearly-labeled local demo mode.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
